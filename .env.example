# Database Configuration
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL="postgresql://user:password@localhost:5432/shopify_bundle_app"

# Shopify App Credentials
# Get these from your Shopify Partner Dashboard
SHOPIFY_API_KEY="your_shopify_api_key_here"
SHOPIFY_API_SECRET="your_shopify_api_secret_here"

# App Configuration
# Set to "production" when deploying to production
NODE_ENV="development"

# Optional: Session Storage
# If using custom session storage, configure here
# SESSION_SECRET="your_session_secret_here"

# Optional: Custom Domain (Production only)
# SHOPIFY_APP_URL="https://your-app-domain.com"
